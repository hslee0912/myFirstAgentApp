{
  "version": "1.0.0",
  "endpoints": [
    {
      "path": "/api/v1/auth/login",
      "method": "POST",
      "description": "이메일/비밀번호 로그인",
      "request": {
        "content_type": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "email",
            "password"
          ],
          "properties": {
            "email": {
              "type": "string",
              "format": "email",
              "maxLength": 255,
              "example": "user@example.com"
            },
            "password": {
              "type": "string",
              "minLength": 1,
              "example": "SecurePass123!"
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "로그인 성공",
          "content_type": "application/json",
          "schema": {
            "type": "object",
            "required": [
              "success",
              "data"
            ],
            "properties": {
              "success": {
                "type": "boolean",
                "const": true
              },
              "data": {
                "type": "object",
                "required": [
                  "user_id"
                ],
                "properties": {
                  "user_id": {
                    "type": "integer",
                    "example": 12345
                  }
                }
              }
            }
          },
          "example": {
            "success": true,
            "data": {
              "user_id": 12345
            }
          }
        },
        "400": {
          "description": "요청 validation 실패",
          "content_type": "application/json",
          "schema": {
            "type": "object",
            "required": [
              "success",
              "error"
            ],
            "properties": {
              "success": {
                "type": "boolean",
                "const": false
              },
              "error": {
                "type": "string",
                "example": "Invalid email format"
              }
            }
          }
        },
        "401": {
          "description": "인증 실패 (이메일 미존재 또는 비밀번호 불일치)",
          "content_type": "application/json",
          "schema": {
            "type": "object",
            "required": [
              "success",
              "error"
            ],
            "properties": {
              "success": {
                "type": "boolean",
                "const": false
              },
              "error": {
                "type": "string",
                "example": "Invalid email or password"
              }
            }
          }
        },
        "500": {
          "description": "서버 내부 오류",
          "content_type": "application/json",
          "schema": {
            "type": "object",
            "required": [
              "success",
              "error"
            ],
            "properties": {
              "success": {
                "type": "boolean",
                "const": false
              },
              "error": {
                "type": "string",
                "example": "Internal server error"
              }
            }
          }
        }
      },
      "security_notes": [
        "bcrypt.compare()로 비밀번호 검증",
        "SQL injection 방지를 위해 prepared statement 사용",
        "401 응답 시 이메일/비밀번호 중 무엇이 틀렸는지 명시하지 않음 (계정 열거 공격 방지)"
      ]
    }
  ]
}
