{
  "path": "/auth/signup",
  "method": "POST",
  "description": "이메일과 비밀번호로 사용자 회원가입",
  "request": {
    "schema": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "사용자 이메일 (유니크)"
        },
        "password": {
          "type": "string",
          "minLength": 8,
          "description": "사용자 비밀번호 (8자 이상)"
        }
      },
      "required": [
        "email",
        "password"
      ]
    },
    "example": {
      "email": "user@example.com",
      "password": "password123"
    }
  },
  "responses": {
    "201": {
      "schema": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "integer",
                "example": 1
              },
              "email": {
                "type": "string",
                "example": "user@example.com"
              },
              "created_at": {
                "type": "string",
                "format": "date-time",
                "example": "2025-01-20T10:30:00Z"
              }
            }
          }
        }
      }
    },
    "400": {
      "schema": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string",
            "example": "이메일 형식이 유효하지 않습니다"
          }
        }
      }
    },
    "409": {
      "schema": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string",
            "example": "이미 가입된 이메일입니다"
          }
        }
      }
    }
  }
}
