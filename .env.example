# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Models — per-agent override; falls back to ANTHROPIC_MODEL, then claude-sonnet-4-5.
# Empty/missing = use the next fallback in the chain.
ANTHROPIC_MODEL=claude-sonnet-4-5
CODECHECKER_MODEL=
BE_AGENT_MODEL=
FE_AGENT_MODEL=

# MySQL (single host DB — agent 도구 + BE 컨테이너 비즈니스 모두 공유)
# D29=A: BE 컨테이너도 host.docker.internal로 이 값을 사용 (compose가 .env에서
# 보간). DB_PASSWORD가 빈 값이면 BE 컨테이너가 인증 실패하며 fail-fast.
# EC2/RDS로 옮길 땐 DB_HOST만 RDS endpoint로 바꾸면 끝.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=myfirstagentapp_db

# App ports
FE_PORT=5173
BE_PORT=3001

# Orchestrator
MAX_RETRIES=3

# Pipeline auto-commit mode (orchestrator only — humans are never gated)
#   auto   — (default) when verdict=PASS, orchestrator runs `git add BE FE`
#            + `git commit` automatically. Push is always left to the human.
#   manual — orchestrator never commits. User commits/pushes manually.
#            (any non-'auto' value behaves the same as 'manual')
COMMIT_MODE=auto

# Validation toggle (Phase 4 Lint Agent: eslint + build + tests)
#   on  — (default) run all 3 stages, retry on failure, FAIL on Stage 3 fail
#   off — skip Phase 4 entirely, mark log_task_state SUCCESS automatically
#         (ablation/debug mode — code lands UNVERIFIED on disk)
#   validatePaths/protectedConfigFiles 같은 안전장치는 모드 무관 항상 켜짐.
VALIDATION_MODE=on

# ====== Phase 8/9 (Deploy + Post-deploy Test) ======

# Container expose ports. 학생 환경에서 host 포트 충돌 시 변경.
# D29=A 이후 mysql 컨테이너는 더 이상 띄우지 않음 (호스트 MySQL 직결) → DEPLOY_PORT_DB 제거.
DEPLOY_PORT_FE=5173
DEPLOY_PORT_BE=3001

# Deploy 토글 (VALIDATION_MODE 패턴 일관)
#   on  — (default) Phase 8 Deploy + Phase 9 PostTest 정상 실행.
#         Docker 미설치 시 verdict=ERROR.
#   off — Phase 8/9 통째 skip + log_agent_runs에 SUCCESS(skipped 표시) 기록.
#         verdict는 Phase 4까지 결과로 결정.
DEPLOY_MODE=on

# Phase 8 timeout (초). docker compose up --build --wait 최대 대기 시간.
DEPLOY_TIMEOUT_SEC=300

# Phase 9 timeout (초). lib/api_test.runContract 전체 호출 최대 시간.
POSTTEST_TIMEOUT_SEC=60

# D83 (2026-05-18): LLM 호출 간 cooldown (ms). cycle latency 단축 토글.
#   LLM_INTER_CALL_MS  — round 내 BE Lint → FE Agent 호출 사이 대기 (default 15000)
#   LLM_INTER_ROUND_MS — round N → round N+1 시작 사이 대기 (default 30000)
# 5000 / 10000 권장 — rate limit 위험 작고 retry 시 -20초/round 절감.
# 너무 작으면 Anthropic 429 (Too Many Requests) 위험 ↑.
LLM_INTER_CALL_MS=5000
LLM_INTER_ROUND_MS=10000

# Docker logs 보존 줄 수. Deploy/PostTest FAIL 시 log_agent_runs.output_json에 service별 마지막 N줄 저장.
LOG_TAIL_LINES=200

# Phase 7.5 teardown 정책
#   on  — (기본) verdict=PASS면 즉시 `docker compose down` (D6=B PASS branch).
#   off — PASS여도 컨테이너 보존. UI의 FE/BE 열기 버튼이 의미를 가지며,
#         사용자가 직접 "Stop containers" 버튼으로 정리. FAIL/ERROR는 정책 무관
#         항상 보존(디버깅용).
DEPLOY_TEARDOWN_ON_PASS=on

# ====== UI control panel ======

# `npm run ui`가 띄우는 Express 서버 포트. orchestrator/BE/FE/DB와 안 겹치는 값.
# 충돌 시 deploy_agent와 동일한 port preflight로 +1..+20 자동 fallback.
UI_PORT=4000

# 브라우저가 FE/BE 컨테이너에 접근할 때 사용하는 호스트.
#   로컬 개발: localhost (기본).
#   EC2/원격 머신: EC2 public DNS 또는 IP (예: ec2-xx.compute.amazonaws.com).
# UI의 "FE/BE 열기" 링크와 Redeploy 완료 메시지가 이 값을 사용.
# 서버 측 DB_HOST(컨테이너 내부 통신)와는 별개 — 이건 브라우저 → 호스트 노출용.
PUBLIC_HOST=localhost
