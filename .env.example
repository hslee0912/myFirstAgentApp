# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Models — per-agent override; falls back to ANTHROPIC_MODEL, then claude-sonnet-4-5.
# Empty/missing = use the next fallback in the chain.
ANTHROPIC_MODEL=claude-sonnet-4-5
CODECHECKER_MODEL=
BE_AGENT_MODEL=
FE_AGENT_MODEL=

# MySQL (single DB for both business and agent logs)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=myfirstagentapp_db

# App ports
FE_PORT=5173
BE_PORT=3001

# Orchestrator
MAX_RETRIES=3

# Pipeline auto-commit mode (orchestrator only — humans are never gated)
#   auto   — (default) when verdict=PASS, orchestrator runs `git add BE FE`
#            + `git commit` automatically. Push is always left to the human.
#   manual — orchestrator never commits. User commits/pushes manually.
#            (any non-'auto' value behaves the same as 'manual')
COMMIT_MODE=auto

# Validation toggle (Phase 4 Lint Agent: eslint + build + tests)
#   on  — (default) run all 3 stages, retry on failure, FAIL on Stage 3 fail
#   off — skip Phase 4 entirely, mark log_task_state SUCCESS automatically
#         (ablation/debug mode — code lands UNVERIFIED on disk)
#   validatePaths/protectedConfigFiles 같은 안전장치는 모드 무관 항상 켜짐.
VALIDATION_MODE=on

# ====== Phase 8/9 (Deploy + Post-deploy Test) ======

# Container expose ports. 학생 환경에서 host 포트 충돌 시 변경.
DEPLOY_PORT_FE=5173
DEPLOY_PORT_BE=3001
DEPLOY_PORT_DB=3306

# Deploy 토글 (VALIDATION_MODE 패턴 일관)
#   on  — (default) Phase 8 Deploy + Phase 9 PostTest 정상 실행.
#         Docker 미설치 시 verdict=ERROR.
#   off — Phase 8/9 통째 skip + log_agent_runs에 SUCCESS(skipped 표시) 기록.
#         verdict는 Phase 4까지 결과로 결정.
DEPLOY_MODE=on

# Phase 8 timeout (초). docker compose up --build --wait 최대 대기 시간.
DEPLOY_TIMEOUT_SEC=300

# Phase 9 timeout (초). lib/api_test.runContract 전체 호출 최대 시간.
POSTTEST_TIMEOUT_SEC=60

# Docker logs 보존 줄 수. Deploy/PostTest FAIL 시 log_agent_runs.output_json에 service별 마지막 N줄 저장.
LOG_TAIL_LINES=200
